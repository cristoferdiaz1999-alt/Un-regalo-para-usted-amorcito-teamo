    <title>Para Victoria ❤️</title>
    <style>
        :root {
            --azul-fondo: #2e41ff;
            --fucsia: #FF1493;
            --dorado: #FFD700;
        }

        body {
            margin: 0;
            font-family: 'Segoe UI', sans-serif;
            background-color: var(--azul-fondo);
            color: white;
            display: flex;
            flex-direction: column;
            align-items: center;
            min-height: 100vh;
            padding: 20px;
            text-align: center;
            transition: background-color 1s ease;
        }

        .card-container {
            width: 100%;
            max-width: 350px;
            margin-top: 10px;
        }

        .portada {
            width: 100%;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.5);
            border: 4px solid white;
        }

        #mensaje-programado {
            margin: 25px 0 10px 0;
            font-size: 1.4rem;
            font-weight: bold;
            color: var(--dorado);
            text-shadow: 1px 1px 5px rgba(0,0,0,0.5);
            min-height: 60px;
            display: flex;
            align-items: center;
            justify-content: center;
            padding: 0 15px;
        }

        #reloj {
            font-size: 2.5rem;
            font-weight: bold;
            margin-bottom: 20px;
        }

        .mensaje-espera {
            font-size: 1.1rem;
            margin-bottom: 25px;
            opacity: 0.9;
        }

        .btn-album {
            background-color: white;
            color: var(--azul-fondo);
            border: none;
            padding: 15px 40px;
            border-radius: 50px;
            font-weight: bold;
            cursor: pointer;
            box-shadow: 0 5px 15px rgba(0,0,0,0.3);
            font-size: 1rem;
        }

        #galeria {
            display: none;
            position: fixed;
            top: 0; left: 0; width: 100%; height: 100%;
            background: rgba(0,0,0,0.98);
            z-index: 1000;
            overflow-y: auto;
            padding: 20px;
        }

        .cerrar {
            position: fixed;
            top: 20px; right: 25px;
            font-size: 3rem;
            color: white;
            cursor: pointer;
            z-index: 1001;
        }

        .grid-fotos {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 12px;
            margin-top: 60px;
            padding-bottom: 40px;
        }

        .grid-fotos div {
            background: #1a1a1a;
            border-radius: 8px;
            aspect-ratio: 1/1;
            overflow: hidden;
            border: 2px solid white;
        }

        .grid-fotos img {
            width: 100%;
            height: 100%;
            object-fit: cover;
        }

        /* ESTILO PARA LA SORPRESA FINAL */
        #sorpresa-final {
            display: none;
            width: 100%;
            height: 100vh;
            justify-content: center;
            align-items: center;
            position: fixed;
            top: 0;
            left: 0;
            z-index: 2000;
            background-color: var(--fucsia);
        }

        .img-sorpresa {
            width: 90%;
            max-width: 500px;
            border-radius: 15px;
            box-shadow: 0 15px 50px rgba(0,0,0,0.6);
            border: 5px solid white;
            animation: aparecer 2s forwards;
        }

        @keyframes aparecer { 
            from { opacity: 0; transform: scale(0.8); } 
            to { opacity: 1; transform: scale(1); } 
        }
    </style>
