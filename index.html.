    <script>
        const frasesRotativas = [
            "❤️ Te amo mi amor", "💖 Te extraño", "✨ Eres mi niña", "🌸 Eres lo más lindo", 
            "💕 Mi vida entera", "👩‍❤️‍👨 Juntos por siempre", "😴 Sueño contigo", "🌅 Despertar a tu lado",
            "💍 Mi futuro es contigo", "🏡 Nuestra vida juntos", "🌟 Eres mi sol", "🔥 Te amo infinito"
        ];

        function actualizarMensajeSegundo() {
            const contenedor = document.getElementById("mensaje-programado");
            if (contenedor) {
                const ahoraEnSegundos = Math.floor(Date.now() / 1000);
                const indice = ahoraEnSegundos % frasesRotativas.length;
                contenedor.innerText = frasesRotativas[indice];
            }
        }

        // FECHA DE LOS 31 AÑOS: 4 DE MAYO
        const cumpleanos = new Date("May 4, 2026 00:00:00").getTime();

        const x = setInterval(function() {
            const ahora = new Date().getTime();
            const faltante = cumpleanos - ahora;

            actualizarMensajeSegundo();

            const d = Math.floor(faltante / (1000 * 60 * 60 * 24));
            const h = Math.floor((faltante % (1000 * 60 * 60 * 24)) / (1000 * 60 * 60));
            const m = Math.floor((faltante % (1000 * 60 * 60)) / (1000 * 60));
            const s = Math.floor((faltante % (1000 * 60)) / 1000);

            document.getElementById("reloj").innerHTML = d + "d " + h + "h " + m + "m " + s + "s ";

            // CUANDO LLEGA A CERO
            if (faltante < 0) {
                clearInterval(x);
                document.getElementById("pantalla-espera").style.display = "none";
                document.getElementById("galeria").style.display = "none";
                document.getElementById("sorpresa-final").style.display = "flex"; // Muestra la imagen centrada
            }
        }, 1000);

        function abrirAlbum() { document.getElementById("galeria").style.display = "block"; }
        function cerrarAlbum() { document.getElementById("galeria").style.display = "none"; }
    </script>
